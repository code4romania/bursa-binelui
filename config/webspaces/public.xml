<?xml version="1.0" encoding="utf-8"?>
<webspace xmlns="http://schemas.sulu.io/webspace/webspace"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://schemas.sulu.io/webspace/webspace http://schemas.sulu.io/webspace/webspace-1.1.xsd">

    <name>bursabinelui.ro</name>
    <key>public</key>

    <localizations>
        <localization language="ro" default="true"/>
        <localization language="en"/>
    </localizations>

    <default-templates>
        <default-template type="page">default</default-template>
        <default-template type="home">homepage</default-template>
    </default-templates>

    <templates>
        <template type="search">search/search</template>
        <template type="error">error/error</template>
    </templates>

    <navigation>
        <contexts>
            <context key="main">
                <meta>
                    <title lang="ro">Main Navigation</title>
                    <title lang="en">Main Navigation</title>
                </meta>
            </context>
            <context key="footer-useful-links">
                <meta>
                    <title lang="ro">Linkuri Utile</title>
                    <title lang="en">Useful links</title>
                </meta>
            </context>
            <context key="footer-quick-nav">
                <meta>
                    <title lang="ro">Navigheaza</title>
                    <title lang="en">Jump to</title>
                </meta>
            </context>
        </contexts>
    </navigation>

    <portals>
        <portal>
            <name>bursabinelui.ro</name>
            <key>public</key>

            <environments>
                <environment type="prod">
                    <urls>
                        <url>{host}/{localization}</url>
                    </urls>
                    <custom-urls>
                        <custom-url>bursabinelui.ro/*</custom-url>
                    </custom-urls>
                </environment>
                <environment type="stage">
                    <urls>
                        <url>{host}/{localization}</url>
                    </urls>
                    <custom-urls>
                        <custom-url>*.*/*</custom-url>
                    </custom-urls>
                </environment>
                <environment type="test">
                    <urls>
                        <url>{host}/{localization}</url>
                    </urls>
                    <custom-urls>
                        <custom-url>*.*/*</custom-url>
                    </custom-urls>
                </environment>
                <environment type="dev">
                    <urls>
                        <url>{host}/{localization}</url>
                    </urls>
                    <custom-urls>
                        <custom-url>*.*/*</custom-url>
                    </custom-urls>
                </environment>
            </environments>
        </portal>
    </portals>
</webspace>
