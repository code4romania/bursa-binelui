<properties xmlns="http://schemas.sulu.io/template/template"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">
    <block name="blocks" default-type="image-slider">
        <types>
            <type name="image-slider">
                <meta>
                    <title lang="ro">Image slider</title>
                    <title lang="en">Image slider</title>
                </meta>
                <properties>
                    <property name="title" type="text_line" mandatory="true">
                        <meta>
                            <title lang="ro">Title - to do replace with image selection</title>
                            <title lang="en">Title - to do replace with image selection</title>
                        </meta>
                    </property>
                </properties>
            </type>
        </types>
    </block>
</properties>
